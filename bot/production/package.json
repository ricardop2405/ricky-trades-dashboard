{
  "name": "ricky-trades-bot",
  "version": "1.0.0",
  "description": "Ricky Trades — Solana MEV + Prediction Market Arbitrage Bot",
  "scripts": {
    "mev": "ts-node --transpile-only src/mev-engine.ts",
    "migration": "ts-node --transpile-only src/migration-engine.ts",
    "scanner": "ts-node --transpile-only src/scanner-engine.ts",
    "arb": "ts-node src/arb-engine.ts",
    "limitless": "ts-node --transpile-only src/limitless-engine.ts",
    "cow": "ts-node --transpile-only src/cow-polymarket-engine.ts",
    "cow-limitless": "ts-node --transpile-only src/cow-limitless-engine.ts",
    "drift-jup": "ts-node --transpile-only src/drift-jupiter-engine.ts",
    "triad": "ts-node --transpile-only src/triad-arb-engine.ts",
    "both": "concurrently \"npm run mev\" \"npm run scanner\"",
    "all": "concurrently \"npm run mev\" \"npm run scanner\" \"npm run arb\" \"npm run limitless\" \"npm run cow\" \"npm run cow-limitless\" \"npm run drift-jup\" \"npm run triad\"",
    "start": "npm run both"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.0",
    "@supabase/supabase-js": "^2.49.1",
    "@triadxyz/triad-protocol": "^0.4.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^16.4.5",
    "https-proxy-agent": "^7.0.4",
    "node-fetch": "^3.3.2",
    "socks-proxy-agent": "^8.0.2",
    "tweetnacl": "^1.0.3",
    "viem": "2.21.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0"
  }
}
