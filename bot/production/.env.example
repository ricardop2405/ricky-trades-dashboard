# ═══════════════════════════════════════════════════════════
#  RICKY TRADES — Bot Configuration
# ═══════════════════════════════════════════════════════════
#
#  SETUP: Copy this file to .env and fill in your keys.
#         cp .env.example .env
#
#  IMPORTANT: No duplicate keys! Each variable once only.
# ═══════════════════════════════════════════════════════════

# ── 1. REQUIRED: Supabase (from Lovable Cloud) ──────────
SUPABASE_URL=https://vpfivkcxtwsnrtuhofyp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste_your_service_role_key_here

# ── 2. REQUIRED FOR MEV BOT: Solana Wallet ──────────────
#    Export your wallet private key as base58 string
SOLANA_PRIVATE_KEY=paste_your_solana_private_key_here

# ── 3. REQUIRED FOR MEV BOT: Helius RPC ─────────────────
#    Sign up at https://helius.dev — get your API key
#    Replace YOUR_KEY with your actual Helius API key
HELIUS_HTTP=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── 4. MEV Bot Settings (sensible defaults) ─────────────
MEV_DRY_RUN=true
MEV_ENTRY_USDC=50000000
WHALE_THRESHOLD=5000
JITO_TIP=10000
MIN_PROFIT=0.10
SOL_PRICE_USD=150
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ── 5. MEV Throttle Settings (tune for your Helius plan) ─
#    Free tier:  PARSED_TX_MIN_INTERVAL_MS=3000, MAX_PENDING_SIGNATURES=30
#    Starter:    PARSED_TX_MIN_INTERVAL_MS=1500, MAX_PENDING_SIGNATURES=100
#    Growth+:    PARSED_TX_MIN_INTERVAL_MS=250,  MAX_PENDING_SIGNATURES=500
PARSED_TX_MIN_INTERVAL_MS=1500
MAX_PENDING_SIGNATURES=100
MAX_GET_TX_RETRIES=2
RATE_LIMIT_BACKOFF_MS=2000

# ── 6. Base Chain (Limitless arb) ────────────────────────
BASE_PRIVATE_KEY=paste_your_base_wallet_private_key_here
BASE_RPC_URL=https://mainnet.base.org
LIMITLESS_API_KEY=
LIMITLESS_OWNER_ID=0
LIMITLESS_MIN_SPREAD=0.015
LIMITLESS_TRADE_SIZE_USD=5
LIMITLESS_SCAN_INTERVAL_MS=8000

# ── 7. Gnosis Chain (Omen arb) ───────────────────────────
GNOSIS_PRIVATE_KEY=paste_your_gnosis_private_key_here
GNOSIS_RPC_URL=https://rpc.gnosischain.com
GRAPH_API_KEY=
GNOSIS_MIN_SPREAD=0.01
GNOSIS_TRADE_SIZE_USD=10
GNOSIS_SCAN_INTERVAL_MS=5000
GNOSIS_DRY_RUN=true

# ── 8. CoW + Polymarket (optional) ──────────────────────
COW_TRADE_SIZE_USD=10
COW_MIN_SPREAD=0.02
COW_SCAN_INTERVAL_MS=5000
COW_DRY_RUN=true
COW_LIMITLESS_DRY_RUN=false
