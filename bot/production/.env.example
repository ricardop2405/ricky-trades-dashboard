# ═══════════════════════════════════════════════════
#  RICKY TRADES — Environment Configuration
# ═══════════════════════════════════════════════════

# ── Solana Wallet (base58 private key) ────────────────
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# ── Helius RPC (get free key at https://helius.dev) ───
HELIUS_RPC_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_HTTP_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Supabase (from your Lovable Cloud project) ───────
SUPABASE_URL=https://vpfivkcxtwsnrtuhofyp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── MEV Engine Settings ──────────────────────────────
JITO_TIP_LAMPORTS=5000000
MIN_PROFIT_USD=0.05
WHALE_THRESHOLD_USD=5000
SOL_PRICE_USD=170
PARSED_TX_MIN_INTERVAL_MS=800
RATE_LIMIT_BACKOFF_MS=2000
MAX_GET_TX_RETRIES=4
MAX_PENDING_SIGNATURES=500

# ── Proxy (route Jupiter API through supported region) ──
PROXY_URL=socks5://user:pass@your-proxy-host:1080

# ── Arb Engine Settings ─────────────────────────────
ARB_AMOUNT_USD=25
MIN_SPREAD=0.03
SCAN_INTERVAL_MS=30000

# ── Drift BET (no key needed — public API) ──────
DRIFT_DATA_API=https://data.api.drift.trade
DRIFT_GATEWAY_URL=http://localhost:8080

# ── DFlow (fallback — requires production key) ──
DFLOW_METADATA_API=https://prediction-markets-api.dflow.net
DFLOW_TRADE_API=https://quote-api.dflow.net
DFLOW_API_KEY=

# ── Jupiter Predict (get key at https://portal.jup.ag)
JUP_PREDICT_API_KEY=your_jupiter_api_key_here

# ── Limitless (Base Chain) — Intra-platform arb ─────
LIMITLESS_API_KEY=your_limitless_api_key_here
BASE_PRIVATE_KEY=your_base_wallet_private_key_here
BASE_RPC_URL=https://mainnet.base.org
LIMITLESS_MIN_SPREAD=0.015
LIMITLESS_TRADE_SIZE_USD=25
LIMITLESS_SCAN_INTERVAL_MS=8000