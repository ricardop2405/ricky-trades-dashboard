# ═══════════════════════════════════════════════════
#  RICKY TRADES — Limitless Arb Configuration
# ═══════════════════════════════════════════════════

# ── Supabase (from your Lovable Cloud project) ───────
SUPABASE_URL=https://vpfivkcxtwsnrtuhofyp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Solana MEV / Atomic Triangular Arb ───────────────────
SOLANA_PRIVATE_KEY=your_solana_wallet_private_key_here
HELIUS_HTTP=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
MEV_DRY_RUN=true
MEV_ENTRY_USDC=50000000
WHALE_THRESHOLD=5000
JITO_TIP=10000
MIN_PROFIT=0.10
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
SOL_PRICE_USD=150

BASE_PRIVATE_KEY=your_base_wallet_private_key_here
BASE_RPC_URL=https://mainnet.base.org

# ── Limitless API ─────────────────────────────────────
LIMITLESS_API_KEY=
LIMITLESS_OWNER_ID=your_limitless_profile_id

# ── Limitless Trade Settings ─────────────────────────
LIMITLESS_MIN_SPREAD=0.015
LIMITLESS_TRADE_SIZE_USD=5
LIMITLESS_SCAN_INTERVAL_MS=8000

# ── Polygon Wallet (for CoW + Polymarket) ────────────
POLYGON_PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Polymarket CLOB Credentials ──────────────────────
# Auto-derived from wallet if not set. Get from Polymarket API settings.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ── Polymarket Trade Settings ────────────────────────
COW_TRADE_SIZE_USD=10
COW_MIN_SPREAD=0.02
COW_SCAN_INTERVAL_MS=5000
COW_MAX_DURATION_MIN=60
COW_DRY_RUN=true

# ── CoW + Limitless (Base) Settings ──────────────────
COW_LIMITLESS_DRY_RUN=false

# ── Gnosis Chain (Omen + Azuro Arb) ─────────────────
GNOSIS_PRIVATE_KEY=your_gnosis_wallet_private_key_here
GNOSIS_RPC_URL=https://rpc.gnosischain.com
GNOSIS_MIN_SPREAD=0.01
GNOSIS_TRADE_SIZE_USD=10
GNOSIS_SCAN_INTERVAL_MS=5000
GNOSIS_DRY_RUN=true
